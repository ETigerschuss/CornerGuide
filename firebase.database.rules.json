{
  "rules": {
    ".read": false,
    ".write": false,

    "config": {
      ".read": true,
      ".write": false
    },

    "accessCodes": {
      ".read": false,
      ".write": false
    },

    "accessGranted": {
      "$uid": {
        ".read": "auth != null && (auth.uid == $uid || root.child('config').child('admins').child(auth.uid).val() === true)",
        ".write": "auth != null && (auth.uid == $uid || root.child('config').child('admins').child(auth.uid).val() === true)",
        ".validate": "newData.isString() && newData.val().length > 0 && root.child('accessCodes').child(newData.val()).exists()"
      }
    },

    "pushTokens": {
      ".read": false,
      "$uid": {
        ".write": "auth != null && ((auth.uid == $uid && root.child('accessGranted').child(auth.uid).exists()) || root.child('config').child('admins').child(auth.uid).val() === true)"
      }
    },

    "userPrefs": {
      "$uid": {
        ".read": "auth != null && (auth.uid == $uid || root.child('config').child('admins').child(auth.uid).val() === true)",
        ".write": "auth != null && ((auth.uid == $uid && root.child('accessGranted').child(auth.uid).exists()) || root.child('config').child('admins').child(auth.uid).val() === true)"
      }
    },

    "userProfiles": {
      "$uid": {
        ".read": "auth != null && (auth.uid == $uid || root.child('config').child('admins').child(auth.uid).val() === true)",
        ".write": "auth != null && ((auth.uid == $uid && root.child('accessGranted').child(auth.uid).exists()) || root.child('config').child('admins').child(auth.uid).val() === true)"
      }
    },

    "recoveryProfiles": {
      "$code": {
        ".read": "auth != null",
        ".write": "auth != null && (root.child('accessGranted').child(auth.uid).exists() || root.child('config').child('admins').child(auth.uid).val() === true)"
      }
    },

    "messages": {
      "$uid": {
        ".read": "auth != null && (auth.uid == $uid || root.child('config').child('admins').child(auth.uid).val() === true)",
        ".write": "auth != null && (root.child('accessGranted').child(auth.uid).exists() || root.child('config').child('admins').child(auth.uid).val() === true)"
      }
    },

    "notify": {
      ".read": false,
      "$eventId": {
        ".write": "auth != null && (root.child('accessGranted').child(auth.uid).exists() || root.child('config').child('admins').child(auth.uid).val() === true)"
      }
    },

    "chats": {
      "$pairId": {
        ".read": "auth != null && $pairId.contains(auth.uid)",
        ".write": "auth != null && $pairId.contains(auth.uid) && root.child('accessGranted').child(auth.uid).exists()"
      }
    },

    "liveLocations": {
      ".read": "auth != null && (root.child('accessGranted').child(auth.uid).exists() || root.child('config').child('admins').child(auth.uid).val() === true)",
      ".write": "auth != null && (root.child('accessGranted').child(auth.uid).exists() || root.child('config').child('admins').child(auth.uid).val() === true)"
    },

    "comments":        { ".read": "auth != null", ".write": "auth != null && (root.child('accessGranted').child(auth.uid).exists() || root.child('config').child('admins').child(auth.uid).val() === true)" },
    "teams":           { ".read": "auth != null", ".write": "auth != null && (root.child('accessGranted').child(auth.uid).exists() || root.child('config').child('admins').child(auth.uid).val() === true)" },
    "customTeams":     { ".read": "auth != null", ".write": "auth != null && (root.child('accessGranted').child(auth.uid).exists() || root.child('config').child('admins').child(auth.uid).val() === true)" },
    "presence":        { ".read": "auth != null", ".write": "auth != null && (root.child('accessGranted').child(auth.uid).exists() || root.child('config').child('admins').child(auth.uid).val() === true)" },
    "points":          { ".read": "auth != null", ".write": "auth != null && (root.child('accessGranted').child(auth.uid).exists() || root.child('config').child('admins').child(auth.uid).val() === true)" },
    "encounters":      { ".read": "auth != null", ".write": "auth != null && (root.child('accessGranted').child(auth.uid).exists() || root.child('config').child('admins').child(auth.uid).val() === true)" },
    "corners":         { ".read": "auth != null", ".write": "auth != null && (root.child('accessGranted').child(auth.uid).exists() || root.child('config').child('admins').child(auth.uid).val() === true)" },
    "captured":        { ".read": "auth != null", ".write": "auth != null && (root.child('accessGranted').child(auth.uid).exists() || root.child('config').child('admins').child(auth.uid).val() === true)" },
    "captureHistory":  { ".read": "auth != null", ".write": "auth != null && (root.child('accessGranted').child(auth.uid).exists() || root.child('config').child('admins').child(auth.uid).val() === true)" },
    "photos":          { ".read": "auth != null", ".write": "auth != null && (root.child('accessGranted').child(auth.uid).exists() || root.child('config').child('admins').child(auth.uid).val() === true)" },
    "emojiVotes":      { ".read": "auth != null", ".write": "auth != null && (root.child('accessGranted').child(auth.uid).exists() || root.child('config').child('admins').child(auth.uid).val() === true)" },
    "cornerVotes":     { ".read": "auth != null", ".write": "auth != null && (root.child('accessGranted').child(auth.uid).exists() || root.child('config').child('admins').child(auth.uid).val() === true)" },
    "barometer":       { ".read": "auth != null", ".write": "auth != null && (root.child('accessGranted').child(auth.uid).exists() || root.child('config').child('admins').child(auth.uid).val() === true)" },
    "visits":          { ".read": "auth != null", ".write": "auth != null && (root.child('accessGranted').child(auth.uid).exists() || root.child('config').child('admins').child(auth.uid).val() === true)" },
    "cornerStatus":    { ".read": "auth != null", ".write": "auth != null && (root.child('accessGranted').child(auth.uid).exists() || root.child('config').child('admins').child(auth.uid).val() === true)" },
    "cornerStatuses":  { ".read": "auth != null", ".write": "auth != null && (root.child('accessGranted').child(auth.uid).exists() || root.child('config').child('admins').child(auth.uid).val() === true)" },
    "achievements":    { ".read": "auth != null", ".write": "auth != null && (root.child('accessGranted').child(auth.uid).exists() || root.child('config').child('admins').child(auth.uid).val() === true)" },
    "checkinFeedback": { ".read": "auth != null", ".write": "auth != null && (root.child('accessGranted').child(auth.uid).exists() || root.child('config').child('admins').child(auth.uid).val() === true)" }
  }
}

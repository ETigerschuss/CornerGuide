{
  "rules": {
    ".read": true,
    ".write": "auth != null && root.child('accessGranted').child(auth.uid).val() == true",
    "accessGranted": {
      "$uid": {
        ".write": "auth != null && auth.uid == $uid"
      }
    },
    "accessCodes": {
      ".write": false
    },
    "pushTokens": {
      ".read": false,
      "$uid": {
        ".write": "auth != null && auth.uid == $uid && root.child('accessGranted').child(auth.uid).val() == true"
      }
    }
  }
}
